  mutation updateServerCacheProfile(
    $id: String!
    $cacheProfile: ServerCacheProfile!
  ) {
    updateServerCacheProfile(id: $id, cacheProfile: $cacheProfile) {
      id
      cacheProfile
    }
  }
`),yZ=new U(q`
  query serverCacheProfileQuery($id: String!) {
    server(id: $id) {
      id
      cacheProfile
    }
  }
`),bZ=new Ri(q`
  mutation purgeServerCache($id: String!) {
    purgeServerCache(id: $id) {
      id
    }
  }
`),xZ=new U(q`
  query serverCacheEvents($id: String!) {
    serviceEvents(
      serviceId: $id
      include: ["DeployStarted", "EdgeCachePurged", "EdgeCacheEnabled"]
      limit: 1
    ) {
      events {
        id
        timestamp
        ... on EdgeCachePurged {
          trigger {
            system
            manual
            user {
              id
              email
              avatarDownload {
                url
              }
            }
          }
        }
        ... on EdgeCacheEnabled {
          trigger {
            system
            manual
            user {
              id
              email
              avatarDownload {
                url
              }
            }
          }
        }
        ... on DeployStarted {
          trigger {
            system
            manual
            user {
              id
              email
              avatarDownload {
                url
              }
            }
          }
        }
      }
