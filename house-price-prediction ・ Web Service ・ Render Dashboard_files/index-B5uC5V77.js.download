  fragment registryCredentialFields on RegistryCredential {
    updatedAt
    createdAt
    createdByEmail
    createdByName
    id
    name
    registryType
    username
  }
`,_A=new U(q`
  query registryCredential($registryCredentialId: String!) {
    registryCredential(id: $registryCredentialId) {
      ...registryCredentialFields
    }
  }
  ${gA}
`),vA=new U(q`
  query registryCredentials($filter: RegistryCredentialFilterInput!) {
