  query diskSnapshots($serverId: String!) {
    server(id: $serverId) {
      id
      disk {
        id
        name
        snapshots {
          createdAt
          instanceId
          snapshotKey
        }
      }
    }
  }
`,Lq=q`
  mutation addDisk($serviceId: String!, $input: DiskInput!) {
    addDiskToServer(serviceId: $serviceId, diskInput: $input) {
      id
      disk {
        id
        name
        mountPath
        sizeGB
      }
    }
  }
`,Rq=q`
  mutation deleteDisk($serviceId: String!) {
    deleteDisk(serviceId: $serviceId) {
      id
      disk {
        id
        name
        mountPath
        sizeGB
      }
    }
  }
`,zq=q`
  mutation updateDisk($serviceId: String!, $input: DiskInput!) {
    updateDisk(serviceId: $serviceId, input: $input) {
      id
      disk {
        id
        name
        mountPath
        sizeGB
      }
    }
  }
`,Bq=q`
