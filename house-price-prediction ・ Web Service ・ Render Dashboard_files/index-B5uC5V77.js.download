  mutation updateWorkflowRootDir(
    $id: String!
    $rootDir: String!
    $buildCommand: String!
    $startCommand: String!
  ) {
    updateWorkflowServiceRootDir(id: $id, rootDir: $rootDir) {
      id
      buildConfig {
        rootDir
      }
    }
    updateWorkflowServiceBuildCommand(id: $id, buildCommand: $buildCommand) {
      id
      buildConfig {
        buildCommand
      }
    }
    updateWorkflowServiceStartCommand(id: $id, startCommand: $startCommand) {
      id
      runCommand
    }
  }
