  query sandboxesForGroup($input: SandboxesForGroupFilterInput!) {
    sandboxesForGroup(input: $input) {
      cursor
      hasMore
      sandboxes {
        id
        __typename
        status
        tags
        createdAt
        startedAt
        endedAt
        networkPolicy
        allowedDomains
        timeoutSeconds
        idleTimeoutSeconds
        source {
          __typename
          ... on SandboxEmailSource {
            email
          }
          ... on SandboxTemplateSource {
            templateId
          }
        }
        region {
          id
          description
        }
        image {
          name
          registryUrl
        }
        plan {
          name
          cpus
          memoryGb
        }
      }
    }
  }
